#!/usr/bin/env bash
#
# Pre-commit hook: runs clang-format on staged C/C++ files.
# If clang-format is not available, the hook is a no-op.
#

CLANG_FORMAT=$(command -v clang-format)

if [ -z "$CLANG_FORMAT" ]; then
  exit 0
fi

# Get staged C/C++ files (added, copied, modified — not deleted)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|hpp|h|c)$')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "========================================"
echo "  pre-commit: running clang-format"
echo "========================================"

for file in $STAGED_FILES; do
  echo "  formatting: $file"
  "$CLANG_FORMAT" -i "$file"
  git add "$file"
done

echo "----------------------------------------"
echo "  done — $(echo "$STAGED_FILES" | wc -l | tr -d ' ') file(s) formatted"
echo "========================================"
