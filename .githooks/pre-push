#!/usr/bin/env bash
#
# Pre-push hook: clean build, test, and optional clang-tidy analysis.
#
# 1. Stashes untracked files and unstaged changes
# 2. Destroys build/ and rebuilds from scratch
# 3. Runs all tests
# 4. Runs clang-tidy (if available) on project source files
# 5. Restores stash on any exit
#

set -euo pipefail

# ── Pretty printing ──────────────────────────────────────────────────────────

BOLD='\033[1m'
DIM='\033[2m'
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
RESET='\033[0m'

PASS_ICON="✔"
FAIL_ICON="✘"
WARN_ICON="⚠"
ARROW="▸"

banner() {
  echo ""
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  echo -e "${BOLD}  $1${RESET}"
  echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
}

step() {
  echo -e "\n${CYAN}${ARROW} $1${RESET}"
}

pass() {
  echo -e "  ${GREEN}${PASS_ICON} $1${RESET}"
}

fail() {
  echo -e "  ${RED}${FAIL_ICON} $1${RESET}"
}

warn() {
  echo -e "  ${YELLOW}${WARN_ICON} $1${RESET}"
}

dim() {
  echo -e "  ${DIM}$1${RESET}"
}

# ── Project root ─────────────────────────────────────────────────────────────

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# ── Stash management ────────────────────────────────────────────────────────

STASH_NAME="pre-push-$(date +%s)"
DID_STASH=false

stash_save() {
  step "Saving working tree state"

  if ! git diff --quiet || ! git diff --cached --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
    git stash push --include-untracked -m "$STASH_NAME" >/dev/null 2>&1
    DID_STASH=true
    pass "Stashed as: ${STASH_NAME}"
  else
    dim "Working tree clean — nothing to stash"
  fi
}

stash_restore() {
  if [ "$DID_STASH" = true ]; then
    echo ""
    step "Restoring working tree state"
    if git stash pop >/dev/null 2>&1; then
      pass "Stash restored"
    else
      fail "Stash pop failed — your changes are still in 'git stash list'"
    fi
  fi
}

# Always restore stash on exit, even on error or Ctrl-C
trap stash_restore EXIT

# ── Timer ────────────────────────────────────────────────────────────────────

SECONDS=0

format_duration() {
  local secs=$1
  if [ "$secs" -ge 60 ]; then
    printf "%dm %ds" $((secs / 60)) $((secs % 60))
  else
    printf "%ds" "$secs"
  fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

banner "pre-push: clean build, test & lint"

stash_save

# ── Clean build ──────────────────────────────────────────────────────────────

step "Removing build/"
rm -rf build/
pass "build/ removed"

step "Configuring (cmake --preset mp)"
if cmake --preset mp; then
  pass "Configuration succeeded"
else
  fail "Configuration failed"
  exit 1
fi

step "Building (cmake --build --preset mp)"
if cmake --build --preset mp; then
  pass "Build succeeded"
else
  fail "Build failed"
  exit 1
fi

# ── Tests ────────────────────────────────────────────────────────────────────

step "Running tests (ctest --preset mp)"
if ctest --preset mp; then
  pass "All tests passed"
else
  fail "Tests failed"
  exit 1
fi

# ── clang-tidy (INCREMENTAL + PARALLEL) ─────────────────────────────────────

CLANG_TIDY=$(command -v clang-tidy || true)
RUN_CLANG_TIDY=$(command -v run-clang-tidy || true)

if [ -n "$CLANG_TIDY" ] && [ -n "$RUN_CLANG_TIDY" ]; then
  step "Running clang-tidy (incremental + parallel)"
  dim "Using: $RUN_CLANG_TIDY"

  # Determine base branch (fallback to origin/main)
  BASE_REF="origin/main"
  if git show-ref --verify --quiet refs/remotes/origin/main; then
    BASE_REF="origin/main"
  elif git show-ref --verify --quiet refs/remotes/origin/master; then
    BASE_REF="origin/master"
  fi

  # Get changed C++ files
  CHANGED_FILES=$(git diff --name-only "$BASE_REF"...HEAD \
    | grep -E '\.(cpp|cc|cxx|hpp|h)$' || true)

  if [ -z "$CHANGED_FILES" ]; then
    dim "No changed C++ files — skipping clang-tidy"
  else
    FILE_COUNT=$(echo "$CHANGED_FILES" | wc -l | tr -d ' ')
    dim "Checking ${FILE_COUNT} changed files..."

    # Detect core count (portable-ish)
    if command -v nproc >/dev/null 2>&1; then
      JOBS=$(nproc)
    else
      JOBS=$(sysctl -n hw.ncpu 2>/dev/null || echo 4)
    fi

    dim "Running with ${JOBS} parallel jobs..."

    echo ""

    # Convert newline-separated → array (safe for spaces)
    mapfile -t FILE_ARRAY <<< "$CHANGED_FILES"

    OUTPUT=$("$RUN_CLANG_TIDY" -p build -j "$JOBS" "${FILE_ARRAY[@]}" 2>&1 || true)

    echo "$OUTPUT"

    echo ""
    step "Unique issues"

    echo "$OUTPUT" | awk '
      /warning:|error:/ {
        if (!seen[$0]++) print
      }
    '

    # Gate on warnings/errors
    if echo "$OUTPUT" | grep -qE '(warning|error):'; then
      echo ""
      fail "clang-tidy reported issues"
      exit 1
    else
      pass "clang-tidy clean"
    fi
  fi

elif [ -n "$CLANG_TIDY" ]; then
  step "clang-tidy"
  warn "run-clang-tidy not found — falling back to serial mode"

  # Fallback: incremental but serial
  CHANGED_FILES=$(git diff --name-only origin/main...HEAD \
    | grep -E '\.(cpp|cc|cxx|hpp|h)$' || true)

  FAILURES=0

  for src in $CHANGED_FILES; do
    FILE_OUTPUT=$("$CLANG_TIDY" -p build "$src" 2>&1 || true)

    if echo "$FILE_OUTPUT" | grep -qE '(warning|error):'; then
      FAILURES=$((FAILURES + 1))
      echo "$FILE_OUTPUT"
    fi
  done

  if [ "$FAILURES" -gt 0 ]; then
    fail "clang-tidy failed on ${FAILURES} files"
    exit 1
  else
    pass "clang-tidy clean"
  fi

else
  step "clang-tidy"
  dim "Not found — skipping"
fi

# ── Summary ──────────────────────────────────────────────────────────────────

ELAPSED=$(format_duration $SECONDS)

banner "pre-push complete (${ELAPSED})"
pass "Build, tests, and lint all passed"
echo ""

exit 0
